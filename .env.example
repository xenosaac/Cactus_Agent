# Copy to .env and fill values. Never commit .env.
VA_MODE=hybrid
GEMINI_API_KEY=your_gemini_key_here

# Optional overrides (defaults in voice_agent/config.py)
# VA_GEMINI_MODEL=gemini-3-pro-preview
# VA_GEMINI_VISION_MODEL=gemini-3-pro-preview
# VA_GEMINI_VISION_TIMEOUT_S=45.0
# VA_GEMINI_VISION_THINKING_LEVEL=low
# VA_BROWSER_MODEL=gemini-2.5-flash
# VA_BROWSER_TEMPERATURE=0.2
# VA_MAX_AGENT_STEPS=10
# VA_TOOL_TIMEOUT_S=90.0
# VA_PLANNER_TEMPERATURE=0.2
# VA_VAD_SILENCE_MS=800
# VA_VAD_MAX_SPEECH_MS=12000
# VA_VAD_THRESHOLD=0.65
# VA_VAD_MIN_SEGMENT_RMS=0.030

# Voice debugging writes captured speech segments to disk. Leave off unless debugging.
# VA_VOICE_DEBUG=0
# VA_VOICE_DEBUG_DIR=logs/voice_debug
